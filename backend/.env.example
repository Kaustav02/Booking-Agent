# LiveKit Configuration (sign up at cloud.livekit.io — free tier available)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# Deepgram STT (sign up at deepgram.com — free $200 credit)
DEEPGRAM_API_KEY=your_deepgram_api_key

# Cartesia TTS (sign up at cartesia.ai — free trial available)
CARTESIA_API_KEY=your_cartesia_api_key
CARTESIA_VOICE_ID=your_cartesia_voice_id

# Groq LLM (sign up at console.groq.com — free tier available)
GROQ_API_KEY=your_groq_api_key

# Database
DB_PATH=mykare.db

# API Server
API_HOST=0.0.0.0
API_PORT=8000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
